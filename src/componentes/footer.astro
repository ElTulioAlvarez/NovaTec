---
/** Footer.astro — NovaTec Business Solutions
 *  Moderno, responsivo, accesible. Incluye:
 *  - Navegación rápida
 *  - Contacto + redes
 *  - CTA “Cotizar”
 *  - Botón “Volver arriba” con smooth scroll
 */
export interface Props {
  logoSrc?: string;
  logoAlt?: string;
  email?: string;
  phone?: string;
  address?: string;
  whatsappHref?: string;
  facebookHref?: string;
  githubHref?: string;
  linkedinHref?: string;
}

const {
  logoSrc = "/",
  logoAlt = "Novatec Business Solutions",
  email = "contacto@novatec.mx",
  phone = "+52 000 000 0000",
  address = "Morelia, Michoacán, MX",
  whatsappHref = "https://wa.me/520000000000?text=Hola%20quiero%20m%C3%A1s%20informaci%C3%B3n%20acerca%20de%20NovaTec!",
  facebookHref = "https://facebook.com",
  githubHref = "https://github.com/ElTulioAlvarez",
  linkedinHref = "https://linkedin.com"
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class="relative mt-24 border-t border-white/10 bg-slate-950 text-slate-300">
  <!-- línea superior con gradiente -->
  <div class="pointer-events-none absolute inset-x-0 -top-px h-px bg-gradient-to-r from-cyan-500/40 via-sky-400/40 to-blue-600/40"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 py-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <div>
        <a href="/" class="group inline-flex items-center gap-3">
          <img src={logoSrc} alt={logoAlt} width="40" height="40" class="h-10 w-10 rounded-md ring-1 ring-white/10 shadow transition group-hover:scale-[1.02]" loading="lazy" />
          <div class="leading-tight">
            <span class="block text-sm font-semibold tracking-wide text-white">NOVATEC</span>
            <span class="text-[11px] text-slate-400">Business Solutions</span>
          </div>
        </a>
        <p class="mt-4 max-w-sm text-sm text-slate-400">
          Soluciones de software, web y marketing digital con enfoque en rendimiento, seguridad y crecimiento.
        </p>
        <div class="mt-4">
          <a href="/contacto" class="inline-flex items-center justify-center rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-500 px-4 py-2 text-sm font-semibold text-white ring-1 ring-inset ring-white/10 shadow transition hover:opacity-95 active:opacity-90">
            Cotizar
          </a>
        </div>
      </div>

      <!-- Navegación -->
      <nav aria-label="Navegación del sitio" class="grid gap-2">
        <h3 class="text-sm font-semibold text-white">Sitio</h3>
        <a href="/" class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5">Inicio</a>
        <a href="/nosotros" class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5">Nosotros</a>
        <a href="/servicios" class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5">Servicios</a>
        <a href="/contacto" class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5">Contacto</a>
      </nav>

      <!-- Servicios (resumen) -->
      <div class="grid gap-2">
        <h3 class="text-sm font-semibold text-white">Qué hacemos</h3>
        <span class="text-sm text-slate-400">Desarrollo Web</span>
        <span class="text-sm text-slate-400">Software a medida</span>
        <span class="text-sm text-slate-400">Venta de Hardware</span>
        <span class="text-sm text-slate-400">Marketing, Redes Sociales & Contenido</span>
        <span class="text-sm text-slate-400">Cloud, Integraciones y Soporte</span>
      </div>

      <!-- Contacto -->
      <div class="grid gap-3">
        <h3 class="text-sm font-semibold text-white">Contacto</h3>
        <p class="text-sm text-slate-400"><span class="text-slate-300">Email:</span> {email}</p>
        <p class="text-sm text-slate-400"><span class="text-slate-300">Tel:</span> {phone}</p>
        <p class="text-sm text-slate-400">{address}</p>

        <div class="mt-1 flex items-center gap-3">
          <!-- WhatsApp -->
          <a href={whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-[radial-gradient(circle_at_30%_30%,#25D366_0%,#128C7E_70%)] text-white transition hover:scale-105">
            <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
              <defs>
                <clipPath id="waClipFooter"><circle cx="12" cy="12" r="11"/></clipPath>
                <radialGradient id="waGlossFooter" cx="30%" cy="25%" r="60%"><stop offset="0" stop-color="#fff" stop-opacity=".9"/><stop offset=".6" stop-color="#fff" stop-opacity=".25"/><stop offset="1" stop-color="#fff" stop-opacity="0"/></radialGradient>
              </defs>
              <circle cx="12" cy="12" r="11" fill="none" stroke="#FFFFFF" stroke-width="1.4"/>
              <g clip-path="url(#waClipFooter)"><ellipse cx="9" cy="7" rx="8.5" ry="5.2" fill="url(#waGlossFooter)"/></g>
              <g transform="translate(12 12) scale(.78) translate(-12 -12)"><path fill="#FFFFFF" d="M19.11 17.32c-.27-.14-1.57-.77-1.81-.85-.24-.09-.42-.14-.6.14-.18.27-.69.85-.84 1.03-.15.18-.31.2-.58.07-.27-.14-1.14-.42-2.17-1.34-.8-.71-1.34-1.59-1.5-1.86-.15-.27-.02-.41.11-.54.11-.11.24-.27.36-.4.12-.13.16-.22.24-.36.08-.14.04-.27-.02-.4-.06-.14-.6-1.45-.82-1.99-.22-.53-.44-.46-.6-.46h-.51c-.17 0-.44.06-.67.31-.23.27-.88.86-.88 2.1 0 1.24.9 2.45 1.02 2.62.12.18 1.77 2.72 4.29 3.81.6.26 1.06.41 1.42.53.6.19 1.15.16 1.58.1.48-.07 1.57-.64 1.79-1.26.22-.63.22-1.17.15-1.29-.06-.11-.24-.18-.5-.31z"/></g>
            </svg>
          </a>

          <!-- Facebook -->
          <a href={facebookHref} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.87v-6.98H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.45h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.98A10 10 0 0 0 22 12z"/></svg>
          </a>

          <!-- GitHub -->
          <a href={githubHref} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M12 .5A12 12 0 0 0 0 12.7c0 5.4 3.4 9.9 8.2 11.5.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.5-1.5-1.9-1.5-1.9-1.2-.8.1-.8.1-.8 1.3.1 2 .2 2.9 1.9 1.2 2 3.2 1.4 4 .9.1-.9.5-1.4.9-1.7-2.6-.3-5.4-1.3-5.4-6a4.7 4.7 0 0 1 1.2-3.2 4.4 4.4 0 0 1 .1-3.2s1-.3 3.3 1.2a11.3 11.3 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.5 1 .2 2.4.1 2.7a4.7 4.7 0 0 1 1.2 3.2c0 4.8-2.8 5.7-5.5 6 .5.4 1 1.2 1 2.5v3.7c0 .3.2.7.8.6A12.2 12.2 0 0 0 24 12.7 12 12 0 0 0 12 .5z"/></svg>
          </a>

          <!-- LinkedIn -->
          <a href={linkedinHref} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M19 3A2.94 2.94 0 0 1 22 6v12a2.94 2.94 0 0 1-3 3H5a2.94 2.94 0 0 1-3-3V6a2.94 2.94 0 0 1 3-3h14ZM8.34 18.33v-8H5.67v8h2.67Zm-.13-9.17a1.55 1.55 0 1 0-1.55-1.55 1.55 1.55 0 0 0 1.55 1.55Zm11.12 9.17v-4.47c0-2.39-1.28-3.5-2.98-3.5a2.59 2.59 0 0 0-2.34 1.28h-.05v-1.1H11.7c.04.73 0 8.08 0 8.08h2.67v-4.51c0-.24.02-.48.09-.65a1.46 1.46 0 0 1 1.36-.96c.96 0 1.34.73 1.34 1.81v4.31h2.67Z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Barra inferior -->
    <div class="flex flex-col items-center justify-between gap-3 border-t border-white/10 py-5 text-xs text-slate-400 sm:flex-row">
      <p>© {year} NovaTec Business Solutions. Todos los derechos reservados.</p>
      <div class="flex items-center gap-4">
        <a href="/aviso-privacidad" class="hover:text-white">Aviso de privacidad</a>
        <a href="/terminos" class="hover:text-white">Términos</a>
        <a href="/sitemap.xml" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>

  <!-- Botón volver arriba -->
  <button id="to-top" class="fixed right-4 bottom-24 md:bottom-6 z-40 inline-flex items-center justify-center rounded-full bg-white/10 p-2 text-white ring-1 ring-white/10 backdrop-blur transition hover:bg-white/20 opacity-0 pointer-events-none" aria-label="Volver arriba">
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>
</footer>

<script is:inline>
  /** @type {HTMLButtonElement|null} */
  const toTop = document.getElementById('to-top');
  const onScroll = () => {
    const show = window.scrollY > 300;
    toTop?.classList.toggle('opacity-0', !show);
    toTop?.classList.toggle('pointer-events-none', !show);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toTop?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
