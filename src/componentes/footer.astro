---
/** Footer.astro — NovaTec Business Solutions (v2 Mejorado)
 *  Diseño más limpio, mejor jerarquía visual y accesibilidad.
 *  - Columnas balanceadas
 *  - Badges para soluciones destacadas
 *  - Oferta comercial con bullets e IDs enlazables
 *  - CTA visible con contraste
 *  - Socials con labels invisibles y estados de foco claros
 */
export interface Props {
  logoSrc?: string;
  logoAlt?: string;
  email?: string;
  phone?: string;
  address?: string;
  whatsappHref?: string;
  facebookHref?: string;
  githubHref?: string;
  linkedinHref?: string;
}

const {
  logoSrc = "/favicon.png",
  logoAlt = "NovaTec Business Solutions",
  email = "contacto@novatec.mx",
  phone = "+52 000 000 0000",
  address = "Morelia, Michoacán, MX",
  whatsappHref = "https://wa.me/520000000000?text=Hola%20quiero%20m%C3%A1s%20informaci%C3%B3n%20acerca%20de%20NovaTec!",
  facebookHref = "https://facebook.com",
  githubHref = "https://github.com/ElTulioAlvarez",
  linkedinHref = "https://linkedin.com",
} = Astro.props;

const year = new Date().getFullYear();
---

<footer
  class="relative mt-24 border-t border-white/10 bg-slate-950/95 text-slate-300"
>
  <!-- línea superior con gradiente -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-px h-px bg-gradient-to-r from-cyan-500/40 via-sky-400/40 to-blue-600/40"
  >
  </div>

  <!-- glow sutil tras el CTA -->
  <div
    aria-hidden
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-32 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(56,189,248,0.20),transparent_60%)]"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <section>
        <a
          href="/"
          class="group inline-flex items-center gap-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded-lg"
        >
          <img
            src={logoSrc}
            alt={logoAlt}
            width="40"
            height="40"
            class="h-10 w-10 rounded-md ring-1 ring-white/10 shadow transition group-hover:scale-[1.02]"
            loading="lazy"
          />
          <div class="leading-tight">
            <span class="block text-sm font-semibold tracking-wide text-white"
              >NOVATEC</span
            >
            <span class="text-[11px] text-slate-400">Business Solutions</span>
          </div>
        </a>
        <p class="mt-4 max-w-sm text-sm text-slate-400">
          Software, hardware y marketing digital para hacer crecer tu operación
          con seguridad y rendimiento.
        </p>
        <div class="mt-4">
          <a
            href="/contacto"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-500 px-4 py-2 text-sm font-semibold text-white ring-1 ring-inset ring-white/10 shadow transition hover:opacity-95 active:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="currentColor"
              aria-hidden="true"
              ><path d="M13 5l7 7-7 7v-4H4v-6h9V5z"></path></svg
            >
            Cotizar ahora
          </a>
        </div>
      </section>

      <!-- Navegación -->
      <nav aria-label="Navegación del sitio" class="grid gap-2">
        <h3 class="text-sm font-semibold text-white">Sitio</h3>
        <a
          href="/"
          class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60"
          >Inicio</a
        >
        <a
          href="/nosotros"
          class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60"
          >Nosotros</a
        >
        <a
          href="/servicios"
          class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60"
          >Servicios</a
        >
        <a
          href="/contacto"
          class="rounded px-1 py-1 text-sm hover:text-white hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60"
          >Contacto</a
        >
      </nav>

      <!-- Servicios (resumen) -->
      <section class="grid gap-3">
        <h3 class="text-sm font-semibold text-white">Qué hacemos</h3>

        <!-- Soluciones destacadas como badges -->
        <div class="flex flex-wrap gap-2">
          <span
            class="inline-flex items-center gap-1 rounded-lg bg-white/5 px-2 py-1 text-xs text-slate-200 ring-1 ring-white/10"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-3.5 w-3.5"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M7 2h10a2 2 0 012 2v3H5V4a2 2 0 012-2zm12 7H5v11a2 2 0 002 2h10a2 2 0 002-2V9zM7 12h6v2H7v-2zm0 4h10v2H7v-2z"
              ></path></svg
            >
            Terminal bancaria
          </span>
          <span
            class="inline-flex items-center gap-1 rounded-lg bg-white/5 px-2 py-1 text-xs text-slate-200 ring-1 ring-white/10"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-3.5 w-3.5"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M4 4h3v2H6v1H4V4zm13 0h3v3h-2V6h-1V4zM4 17h2v-1h1v-2H4v3zm16-3h-3v2h1v1h2v-3zM8 10h8v4H8v-4zm4-2a2 2 0 110-4 2 2 0 010 4zm0 12a2 2 0 110-4 2 2 0 010 4z"
              ></path></svg
            >
            Dron HD
          </span>
        </div>

        <!-- Catálogo de productos y servicios -->
        <div class="mt-3 grid gap-2">
          <h4 class="text-xs font-semibold text-slate-300">Oferta comercial</h4>
          <ul class="space-y-1">
            <li class="text-sm text-slate-400">
              <a
                id="software"
                href="/servicios#software"
                class="hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded px-1"
              >
                1) Software: POS, admin, CRM, ERP, facturación, a medida
              </a>
            </li>
            <li class="text-sm text-slate-400">
              <a
                id="hardware"
                href="/servicios#hardware"
                class="hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded px-1"
              >
                2) Hardware: equipos, tabletas, impresoras, cajones, lectores,
                terminales
              </a>
            </li>
            <li class="text-sm text-slate-400">
              <a
                id="inventarios"
                href="/servicios#inventarios"
                class="hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded px-1"
              >
                3) Inventarios físicos: realización, consultoría y bases de
                datos
              </a>
            </li>
            <li class="text-sm text-slate-400">
              <a
                id="marketing"
                href="/servicios#marketing"
                class="hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded px-1"
              >
                4) Social media & Web: perfiles, identidad, web, e‑commerce,
                apps, campañas
              </a>
            </li>
            <li class="text-sm text-slate-400">
              <a
                id="ventas"
                href="/servicios#ventas"
                class="hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60 rounded px-1"
              >
                5) Ventas: consultoría, asesoría y capacitación
              </a>
            </li>
          </ul>
        </div>
      </section>

      <!-- Contacto -->
      <address class="not-italic grid gap-3">
        <h3 class="text-sm font-semibold text-white">Contacto</h3>
        <p class="text-sm text-slate-400">
          <span class="text-slate-300">Email:</span>
          <a href={`mailto:${email}`} class="hover:text-white">{email}</a>
        </p>
        <p class="text-sm text-slate-400">
          <span class="text-slate-300">Tel:</span>
          <a href={`tel:${phone.replace(/\s/g, "")}`} class="hover:text-white"
            >{phone}</a
          >
        </p>
        <p class="text-sm text-slate-400">{address}</p>

        <div class="mt-1 flex items-center gap-3">
          <!-- WhatsApp -->
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white hover:bg-white/10 ..."
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="9"></circle>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.5 14.2c-.9.5-1.3.9-2.6 0s-2.2-2-2.6-2.6.0-1.7 0-2.6"
              ></path>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href={facebookHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
          >
            <span class="sr-only">Abrir Facebook</span>
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M22 12a10 10 0 1 0-11.56 9.87v-6.98H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.45h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.98A10 10 0 0 0 22 12z"
              ></path></svg
            >
          </a>

          <!-- GitHub -->
          <a
            href={githubHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-300"
          >
            <span class="sr-only">Abrir GitHub</span>
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M12 .5A12 12 0 0 0 0 12.7c0 5.4 3.4 9.9 8.2 11.5.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.5-1.5-1.9-1.5-1.9-1.2-.8.1-.8.1-.8 1.3.1 2 .2 2.9 1.9 1.2 2 3.2 1.4 4 .9.1-.9.5-1.4.9-1.7-2.6-.3-5.4-1.3-5.4-6a4.7 4.7 0 0 1 1.2-3.2 4.4 4.4 0 0 1 .1-3.2s1-.3 3.3 1.2a11.3 11.3 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.5 1 .2 2.4.1 2.7a4.7 4.7 0 0 1 1.2 3.2c0 4.8-2.8 5.7-5.5 6 .5.4 1 1.2 1 2.5v3.7c0 .3.2.7.8.6A12.2 12.2 0 0 0 24 12.7 12 12 0 0 0 12 .5z"
              ></path></svg
            >
          </a>

          <!-- LinkedIn -->
          <a
            href={linkedinHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full ring-1 ring-white/10 bg-white/5 text-white transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-300"
          >
            <span class="sr-only">Abrir LinkedIn</span>
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M19 3A2.94 2.94 0 0 1 22 6v12a2.94 2.94 0 0 1-3 3H5a2.94 2.94 0 0 1-3-3V6a2.94 2.94 0 0 1 3-3h14ZM8.34 18.33v-8H5.67v8h2.67Zm-.13-9.17a1.55 1.55 0 1 0-1.55-1.55 1.55 1.55 0 0 0 1.55 1.55Zm11.12 9.17v-4.47c0-2.39-1.28-3.5-2.98-3.5a2.59 2.59 0 0 0-2.34 1.28h-.05v-1.1H11.7c.04.73 0 8.08 0 8.08h2.67v-4.51c0-.24.02-.48.09-.65a1.46 1.46 0 0 1 1.36-.96c.96 0 1.34.73 1.34 1.81v4.31h2.67Z"
              ></path></svg
            >
          </a>
        </div>
      </address>
    </div>

    <!-- Barra inferior -->
    <div
      class="flex flex-col items-center justify-between gap-3 border-t border-white/10 py-5 text-xs text-slate-400 sm:flex-row"
    >
      <p>
        © {year} NovaTec Business Solutions. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a href="/aviso-privacidad" class="hover:text-white"
          >Aviso de privacidad</a
        >
        <a href="/terminos" class="hover:text-white">Términos</a>
        <a href="/sitemap.xml" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>

  <!-- Botón volver arriba -->
  <button
    id="to-top"
    class="fixed right-4 bottom-24 md:bottom-6 z-40 inline-flex items-center justify-center rounded-full bg-white/10 p-2 text-white ring-1 ring-white/10 backdrop-blur transition hover:bg-white/20 opacity-0 pointer-events-none focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400/60"
    aria-label="Volver arriba"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-5 w-5"
      fill="none"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 15l7-7 7 7"></path>
    </svg>
  </button>
</footer>

<script type="module" is:inline>
  (() => {
    // Evita inicializar dos veces (HMR o múltiples renders)
    if (window.__novatecToTopInit) return;
    window.__novatecToTopInit = true;

    const btn = document.getElementById("to-top");
    if (!btn) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    const toggleToTopVisibility = () => {
      const show = window.scrollY > 200;
      btn.style.opacity = show ? "1" : "0";
      btn.style.pointerEvents = show ? "auto" : "none";
    };

    window.addEventListener("scroll", toggleToTopVisibility, { passive: true });
    toggleToTopVisibility();

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: prefersReduced ? "auto" : "smooth" });
    });
  })();
</script>
