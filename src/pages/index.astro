---
import Navbar from "../componentes/navbar.astro";
import Footer from "../componentes/footer.astro";
import SEO from "../componentes/seo.astro";
import CircuitBG from "../componentes/CircuitBG.astro";
import "../styles/global.css";

const title = "NovaTec Business Solutions — Software, Hardware y Servicios";
const description = "Soluciones integrales: punto de venta, sistemas administrativos, CRM/ERP, facturación, hardware, inventarios, marketing digital y capacitación de ventas.";

---

<html lang="es">
  
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/novatec-logo.webp" />
    <SEO title={title} description={description} type="website" locale="es_MX" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 selection:bg-cyan-500/30 selection:text-white">
    <Navbar logoSrc="/novatec-logo.webp"/>
    <CircuitBG />
    <!-- HERO -->
    <header class="relative overflow-hidden">
      <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-10 lg:pt-24 lg:pb-16">
        <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div class="space-y-6">
            <span class="inline-flex items-center rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs tracking-wide text-cyan-200">Soluciones para negocios</span>
            <h1 class="text-3xl font-extrabold sm:text-4xl lg:text-5xl leading-tight">
              Software, hardware y marketing para acelerar tu operación
            </h1>
            <p class="text-slate-300/90 text-lg">
              En <strong>NovaTec Business Solutions</strong> integramos tecnología de punta con procesos claros.
              Desde punto de venta y ERP, hasta inventarios físicos, terminales de cobro y crecimiento en redes.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="#catalogo" class="inline-flex items-center gap-2 rounded-xl bg-cyan-500/90 px-5 py-3 font-semibold text-slate-900 hover:bg-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-300">
                Ver catálogo
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M13 5l7 7-7 7v-4H4v-6h9V5z"/></svg>
              </a>
              <a href="#contacto" class="inline-flex items-center gap-2 rounded-xl border border-slate-700 px-5 py-3 font-semibold text-slate-100 hover:bg-slate-900/50">
                Solicitar cotización
              </a>
            </div>
          </div>

          <!-- Destacados rápidos: Terminal y Dron -->
          <div class="grid gap-6 sm:grid-cols-2">
            <!-- Terminal de cobro -->
            <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-lg shadow-cyan-900/10">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/15">
                <!-- ícono terminal POS -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
                  <path d="M7 2h10a2 2 0 012 2v3H5V4a2 2 0 012-2zm12 7H5v11a2 2 0 002 2h10a2 2 0 002-2V9zM7 12h6v2H7v-2zm0 4h10v2H7v-2z"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold">Terminal para cobro con tarjeta</h3>
              <p class="mt-2 text-sm text-slate-300/90">Integramos terminales físicas y cobro por enlace con tu <span class="whitespace-nowrap">Punto de Venta</span> y sistemas de facturación.</p>
            </article>

            <!-- Dron con cámara -->
            <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-lg shadow-cyan-900/10">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/15">
                <!-- ícono dron -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
                  <path d="M4 4h3v2H6v1H4V4zm13 0h3v3h-2V6h-1V4zM4 17h2v-1h1v-2H4v3zm16-3h-3v2h1v1h2v-3zM8 10h8v4H8v-4zm4-2a2 2 0 110-4 2 2 0 010 4zm0 12a2 2 0 110-4 2 2 0 010 4z"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold">Dron con cámara de alta calidad</h3>
              <p class="mt-2 text-sm text-slate-300/90">Servicios de foto/video aéreo para inventarios, inspecciones, marketing visual y cobertura de eventos.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- fondo sutil -->
      <div aria-hidden class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(75%_75%_at_50%_0%,rgba(56,189,248,0.15)_0%,rgba(15,23,42,0)_60%)]"></div>
    </header>

    <!-- CATÁLOGO / OFERTA COMERCIAL -->
    <section id="catalogo" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
      <header class="mb-10">
        <h2 class="text-2xl sm:text-3xl font-extrabold">Oferta Comercial — Catálogo de productos y servicios</h2>
        <p class="mt-2 text-slate-300/90">Paquetes ajustables a la necesidad de tu operación. Implementación, soporte y capacitación incluidos según alcance.</p>
      </header>

      <div class="grid gap-6 lg:grid-cols-2">
        <!-- 1. Software -->
        <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
          <h3 class="text-xl font-bold">1) Software</h3>
          <ul class="mt-3 space-y-2 text-slate-300/90 list-disc list-inside">
            <li>Punto de Venta (POS)</li>
            <li>Sistema administrativo</li>
            <li>CRM / ERP</li>
            <li>Facturación electrónica</li>
            <li>Desarrollo a medida</li>
          </ul>
        </article>

        <!-- 2. Hardware -->
        <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
          <h3 class="text-xl font-bold">2) Hardware</h3>
          <ul class="mt-3 space-y-2 text-slate-300/90 list-disc list-inside">
            <li>Equipos de cómputo y tabletas</li>
            <li>Impresoras y cajones de dinero</li>
            <li>Lectores de códigos de barras</li>
            <li>Terminales para cobro con tarjeta</li>
          </ul>
        </article>

        <!-- 3. Inventarios físicos -->
        <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
          <h3 class="text-xl font-bold">3) Gestión de inventarios físicos</h3>
          <ul class="mt-3 space-y-2 text-slate-300/90 list-disc list-inside">
            <li>Realización de inventarios físicos</li>
            <li>Consultoría y asesoría</li>
            <li>Creación y depuración de bases de datos</li>
          </ul>
        </article>

        <!-- 4. Social Media / Web -->
        <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
          <h3 class="text-xl font-bold">4) Manejo y gestión de plataformas social media</h3>
          <ul class="mt-3 space-y-2 text-slate-300/90 list-disc list-inside">
            <li>Creación de perfiles corporativos</li>
            <li>Diseño de logotipos e identidad</li>
            <li>Páginas web, tienda en línea y apps</li>
            <li>Creación de contenido y campañas de publicidad digital</li>
          </ul>
        </article>

        <!-- 5. Proceso de ventas -->
        <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 lg:col-span-2">
          <h3 class="text-xl font-bold">5) Proceso de ventas</h3>
          <ul class="mt-3 space-y-2 text-slate-300/90 list-disc list-inside">
            <li>Consultoría de proceso comercial</li>
            <li>Asesoría y auditoría de embudo</li>
            <li>Capacitación a equipos de ventas</li>
          </ul>
        </article>
      </div>

      <!-- CTA intermedio -->
      <div class="mt-10 flex flex-col items-start gap-4 rounded-2xl border border-cyan-500/20 bg-cyan-500/5 p-6 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-slate-200">
          ¿Necesitas una solución específica (por ejemplo, POS + terminal + facturación)? Preparamos un paquete a tu medida.
        </p>
        <a href="#contacto" class="inline-flex items-center gap-2 rounded-xl bg-cyan-500/90 px-5 py-3 font-semibold text-slate-900 hover:bg-cyan-400">Solicitar propuesta</a>
      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contacto" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20">
      <div class="grid gap-8 lg:grid-cols-2">
        <div>
          <h3 class="text-2xl font-extrabold">Hablemos de tu proyecto</h3>
          <p class="mt-2 text-slate-300/90">Cuéntanos sobre tu operación actual y los resultados que buscas; te enviaremos una propuesta clara y un cronograma de implementación.</p>
          <ul class="mt-6 space-y-3 text-slate-300/90">
            <li class="flex items-center gap-3">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-800">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M21 8V7l-3 2-2-1-2 1-2-1-2 1-2-1-3 2v1l3-2 2 1 2-1 2 1 2-1 2 1 3-2z"/></svg>
              </span>
              Integraciones POS, terminal bancaria y facturación
            </li>
            <li class="flex items-center gap-3">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-800">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M3 5h18v2H3V5zm2 4h14v10H5V9zm2 2v6h10v-6H7z"/></svg>
              </span>
              Inventarios físicos y creación de bases de datos
            </li>
            <li class="flex items-center gap-3">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-800">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 3l4 4h-3v6h-2V7H8l4-4zm7 14v2H5v-2h14z"/></svg>
              </span>
              Marketing digital y contenido para redes
            </li>
          </ul>
        </div>

        <form class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 space-y-4">
          <div>
            <label class="text-sm text-slate-300">Nombre</label>
            <input type="text" class="mt-1 w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 outline-none focus:border-cyan-400" placeholder="Tu nombre" />
          </div>
          <div>
            <label class="text-sm text-slate-300">Correo electrónico</label>
            <input type="email" class="mt-1 w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 outline-none focus:border-cyan-400" placeholder="tunombre@empresa.com" />
          </div>
          <div>
            <label class="text-sm text-slate-300">Mensaje</label>
            <textarea rows="4" class="mt-1 w-full rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 outline-none focus:border-cyan-400" placeholder="Cuéntanos qué necesitas (ej. POS con inventario y facturación)"></textarea>
          </div>
          <button type="submit" class="w-full rounded-xl bg-cyan-500/90 px-5 py-3 font-semibold text-slate-900 hover:bg-cyan-400">Enviar</button>
        </form>
      </div>
    </section>

    <Footer logoSrc="/novatec-logo.webp"/>
  </body>
</html>

<SEO
  title="NovaTec Business Solutions — Software, Hardware y Servicios"
  description="Soluciones integrales: POS, CRM/ERP, facturación, hardware, inventarios y marketing digital."
  type="website"
  locale="es_MX"
  url="https://novatec.vercel.app/"
  siteName="NovaTec Business Solutions"
  ogImage="/og-default.png"
  logo="/logo-novatec.png"
  phone="+52 443 371 1589"
  email="contacto@novatec.mx"
  address={{
    streetAddress: "Av. Principal 123",
    addressLocality: "Morelia",
    addressRegion: "Michoacán",
    postalCode: "58000",
    addressCountry: "MX"
  }}
/>
